# ============================================================
# 환경변수 템플릿 — 이 파일을 backend/.env로 복사하여 사용
# cp .env.example backend/.env
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
DEBUG=true                   # true면 상세 에러 노출 + SQL echo

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
DATABASE_SYNC_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot

# ── Redis ───────────────────────────────────────────────────
# 로컬 개발용 (비밀번호 없음). Docker Compose는 REDIS_PASSWORD 사용.
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────
# 반드시 변경! 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── RunPod (GPU 추론) ──────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_LTX_ENDPOINT_ID=          # LTX-Video-2 영상 생성 전용

# ── External LLM APIs (선택) ───────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Observability (선택) ───────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
SENTRY_DSN=

# ── TTS (음성 합성) ───────────────────────────────────────
TTS_PROVIDER=openai              # openai | elevenlabs
TTS_DEFAULT_VOICE=alloy          # OpenAI: alloy|echo|fable|onyx|nova|shimmer
TTS_OUTPUT_FORMAT=mp3            # mp3 | opus | aac | wav
TTS_ENABLED=true
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# ── Image Generation (이미지 생성) ────────────────────────
IMAGE_GEN_PROVIDER=openai        # openai | stability
IMAGE_GEN_DEFAULT_STYLE=anime
IMAGE_GEN_ENABLED=true
STABILITY_API_KEY=

# ── Pipeline (ML 모델) ─────────────────────────────────────
# 비워두면 자동 감지 (CUDA 있으면 cuda, 없으면 cpu)
PIPELINE_DEVICE=
PIPELINE_LAZY_LOAD=true      # true면 첫 호출 시 모델 로드

# ── Credits & Quotas ────────────────────────────────────────
# ⚠️ 운영 환경에서 반드시 true — false이면 플랫폼 API 키로 무제한 LLM 호출 허용 (비용 폭증 위험)
CREDIT_SYSTEM_ENABLED=true
FREE_DAILY_CREDITS=50
QUOTA_ENABLED=true

# ── Debate Platform ────────────────────────────────────────
DEBATE_ENABLED=true          # AI 토론 기능 활성화

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=20           # /api/auth/* 분당 제한
RATE_LIMIT_CHAT=30           # /api/chat/* 분당 제한
RATE_LIMIT_API=60            # /api/* 분당 제한

# ── Docker Compose 전용 (로컬 개발 시 아래 값 사용) ─────────
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_dev_pw_2026
REDIS_PASSWORD=redis_dev_pw_2026
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_dev_pw_2026
LANGFUSE_NEXTAUTH_SECRET=langfuse-nextauth-dev-secret-2026
LANGFUSE_SALT=langfuse-salt-dev-secret-2026
