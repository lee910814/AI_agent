# ============================================================
# 개발 서버 환경변수 — dev EC2에서 이 파일을 .env.dev로 복사 후 채움
# cp .env.development.example .env.dev
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Database (개발 전용 DB — prod와 분리) ────────────────────
DATABASE_URL=postgresql+asyncpg://chatbot:CHANGE_ME@chatbot-dev-db:5432/chatbot_dev
DATABASE_SYNC_URL=postgresql://chatbot:CHANGE_ME@chatbot-dev-db:5432/chatbot_dev

POSTGRES_DB=chatbot_dev
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis (개발 전용) ────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@chatbot-dev-redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# ── Auth ────────────────────────────────────────────────────
# 개발용 시크릿 키 (prod와 다른 값 사용)
SECRET_KEY=CHANGE_ME_DEV
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 개발 편의용 7일

# ── CORS ────────────────────────────────────────────────────
# 개발 EC2 IP 또는 localhost 허용
CORS_ORIGINS=["http://DEV_EC2_IP:8080","http://localhost:3000"]

# ── 토론 기능 ────────────────────────────────────────────────
DEBATE_ENABLED=true

# ── LLM API 키 (개발용 — prod와 동일 키 또는 별도 계정) ──────
OPENAI_API_KEY=

# ── 기능 플래그 (개발 환경: 느슨하게) ──────────────────────
CREDIT_SYSTEM_ENABLED=true
FREE_DAILY_CREDITS=9999        # 개발 중 크레딧 소진 방지
QUOTA_ENABLED=false            # 개발 중 쿼터 제한 비활성화
PIPELINE_LAZY_LOAD=true
RATE_LIMIT_ENABLED=false       # 개발 중 레이트 리밋 비활성화
TTS_ENABLED=false
IMAGE_GEN_ENABLED=false

# ── 성인인증 (개발 편의) ────────────────────────────────────
# 개발 환경에서는 자가선언 허용
ALLOW_SELF_DECLARE=true
