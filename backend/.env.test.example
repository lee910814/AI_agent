# ============================================================
# 테스트 환경변수 템플릿 — 이 파일을 backend/.env.test로 복사
# cp backend/.env.test.example backend/.env.test
# (scripts/setup.sh가 자동 복사함)
# ============================================================
# 주의: 실제 API 키는 여기에 커밋하지 않습니다.
#       LLM 통합 테스트가 필요한 경우에만 아래 키를 입력하세요.
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Database (docker-compose.test.yml, 포트 5433) ───────────
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_test_pw@127.0.0.1:5433/chatbot_test
DATABASE_SYNC_URL=postgresql://chatbot:chatbot_test_pw@127.0.0.1:5433/chatbot_test

# ── Redis (docker-compose.test.yml, 포트 6380) ──────────────
REDIS_URL=redis://:test_redis_pw@127.0.0.1:6380/0

# ── Auth ────────────────────────────────────────────────────
# 테스트 전용 키 — 운영 환경에 절대 사용 금지
SECRET_KEY=test-secret-key-do-not-use-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Feature Flags (테스트 편의 설정) ────────────────────────
DEBATE_ENABLED=true
QUOTA_ENABLED=false
RATE_LIMIT_ENABLED=false
CREDIT_SYSTEM_ENABLED=false

# ── Pipeline ────────────────────────────────────────────────
# 첫 호출 시 모델 로드 — 테스트 시작 속도 개선
PIPELINE_LAZY_LOAD=true

# ── LLM API 키 (통합 테스트용, 단위 테스트는 불필요) ─────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
