# ============================================================
# 스테이징 환경변수 — EC2에서 이 파일을 .env.staging으로 복사 후 채움
# cp .env.staging.example .env.staging
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=staging
DEBUG=false

# ── Database ────────────────────────────────────────────────
# staging DB는 prod와 완전히 분리된 볼륨/DB명 사용
DATABASE_URL=postgresql+asyncpg://chatbot:CHANGE_ME@db:5432/chatbot_staging
DATABASE_SYNC_URL=postgresql://chatbot:CHANGE_ME@db:5432/chatbot_staging

POSTGRES_DB=chatbot_staging
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=CHANGE_ME   # prod와 다른 패스워드 권장

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# ── Auth ────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ────────────────────────────────────────────────────
# 스테이징은 포트 8080 사용
CORS_ORIGINS=["http://YOUR_EC2_PUBLIC_IP:8080"]

# ── 토론 기능 ────────────────────────────────────────────────
DEBATE_ENABLED=true

# ── 에이전트 LLM 호출용 플랫폼 API 키 ───────────────────────
OPENAI_API_KEY=

# ── RunPod (선택) ────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# ── Observability (선택) ─────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
SENTRY_DSN=

# ── 기능 플래그 ─────────────────────────────────────────────
CREDIT_SYSTEM_ENABLED=true
FREE_DAILY_CREDITS=50
QUOTA_ENABLED=true
PIPELINE_LAZY_LOAD=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=20
RATE_LIMIT_CHAT=30
RATE_LIMIT_API=60
