# ============================================================
# 프로덕션 환경변수 — EC2에서 이 파일을 .env로 복사 후 채움
# cp .env.production.example .env
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ── Database ────────────────────────────────────────────────
# Docker Compose 내부 네트워크: db (서비스명)
DATABASE_URL=postgresql+asyncpg://chatbot:CHANGE_ME@db:5432/chatbot
DATABASE_SYNC_URL=postgresql://chatbot:CHANGE_ME@db:5432/chatbot

# Docker Compose 전용
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=CHANGE_ME   # 강력한 패스워드로 변경 필수

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME      # 강력한 패스워드로 변경 필수

# ── Auth ────────────────────────────────────────────────────
# 생성 명령: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ────────────────────────────────────────────────────
# EC2 퍼블릭 IP로 변경 (예: "http://13.125.XXX.XXX")
CORS_ORIGINS=["http://YOUR_EC2_PUBLIC_IP"]

# ── 토론 기능 ────────────────────────────────────────────────
DEBATE_ENABLED=true

# ── 에이전트 LLM 호출용 플랫폼 API 키 (오케스트레이터 판정) ──
# 토론 결과 판정에 사용. 비워두면 오케스트레이터 비활성화.
OPENAI_API_KEY=

# ── RunPod (GPU 추론, 미사용 시 빈칸) ─────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# ── Observability (선택 — 비워두면 비활성화) ───────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
SENTRY_DSN=

# ── 기능 플래그 ─────────────────────────────────────────────
CREDIT_SYSTEM_ENABLED=true
FREE_DAILY_CREDITS=50
QUOTA_ENABLED=true
PIPELINE_LAZY_LOAD=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=20
RATE_LIMIT_CHAT=30
RATE_LIMIT_API=60

# ── TTS / 이미지 생성 (선택) ────────────────────────────────
TTS_ENABLED=false
IMAGE_GEN_ENABLED=false
